# Demo C — 云端规划 LLM 配置
# 复制为 .env 并填入真实 key

# GLM-4-Flash (智谱 AI)
PLANNER_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
PLANNER_LLM_API_KEY=your-glm-key-here
PLANNER_LLM_MODEL=glm-4-flash

# 或 DeepSeek（base_url 包含 /v1）
# PLANNER_LLM_BASE_URL=https://api.deepseek.com/v1
# PLANNER_LLM_API_KEY=your-deepseek-key-here
# PLANNER_LLM_MODEL=deepseek-chat

# Mock 模式（=1 跳过真实 API 调用，用于流程验证）
# PLANNER_LLM_MOCK=1
# UITARS_GROUNDING_MOCK=1
